# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AIgnition API
APP_VERSION=1.0.0
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend origin here (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOADS_DIR=app/storage/uploads
MAX_UPLOAD_SIZE_MB=50

# ── ML / LLM Interface ────────────────────────────────────────────────────────
# Set to false to surface NotImplementedError instead of using mock fallback
ML_FALLBACK_ENABLED=true

# ── Report ────────────────────────────────────────────────────────────────────
REPORT_COMPANY_NAME=AIgnition
